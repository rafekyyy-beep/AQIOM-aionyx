/**
 * Rate Limiting موزع باستخدام Upstash Redis
 * npm install @upstash/redis @upstash/ratelimit
 */

import { Ratelimit } from '@upstash/ratelimit';
import { Redis } from '@upstash/redis';
import { NextRequest, NextResponse } from 'next/server';

// تهيئة Redis (استخدم متغيرات البيئة)
const redis = new Redis({
  url: process.env.UPSTASH_REDIS_REST_URL!,
  token: process.env.UPSTASH_REDIS_REST_TOKEN!,
});

// إنشاء rate limiter بمعدلات مختلفة
export const chatRateLimiter = new Ratelimit({
  redis,
  limiter: Ratelimit.slidingWindow(30, '60 s'), // 30 طلب في الدقيقة
  analytics: true,
});

export const authRateLimiter = new Ratelimit({
  redis,
  limiter: Ratelimit.slidingWindow(5, '900 s'), // 5 محاولات في 15 دقيقة
  analytics: true,
});

export const uploadRateLimiter = new Ratelimit({
  redis,
  limiter: Ratelimit.slidingWindow(10, '3600 s'), // 10 رفع في الساعة
  analytics: true,
});

// Middleware helper
export async function withRateLimit(
  request: NextRequest,
  limiter: Ratelimit,
  identifier?: string
): Promise<{ success: boolean; limit: number; remaining: number; reset: number } | null> {
  const ip = request.headers.get('x-forwarded-for')?.split(',')[0] || 'unknown';
  const id = identifier || ip;
  
  const { success, limit, remaining, reset } = await limiter.limit(id);
  
  if (!success) {
    return { success, limit, remaining, reset };
  }
  
  return null;
}
